<!--
  OpenTelemetry dependencies for {{ service_name }} ({{ framework.label }}).

  Merge the <dependencyManagement> and <dependencies> entries below into your
  own pom.xml. The BOM pins every OpenTelemetry artifact to one consistent
  version, so the individual dependencies stay version-free.

  Generated by {{ generator }}.
  Background reading: {{ article }}
-->
<project>
  <properties>
    <opentelemetry.version>1.47.0</opentelemetry.version>
    <opentelemetry.instrumentation.version>2.13.3</opentelemetry.instrumentation.version>
  </properties>

  <dependencyManagement>
    <dependencies>
      <dependency>
        <groupId>io.opentelemetry</groupId>
        <artifactId>opentelemetry-bom</artifactId>
        <version>${opentelemetry.version}</version>
        <type>pom</type>
        <scope>import</scope>
      </dependency>
    </dependencies>
  </dependencyManagement>

  <dependencies>
    <!-- The API is the only OpenTelemetry artifact your business code should
         import. Keep the SDK out of library modules. -->
    <dependency>
      <groupId>io.opentelemetry</groupId>
      <artifactId>opentelemetry-api</artifactId>
    </dependency>

{% if framework.key == 'spring-boot-agent' %}
    <!-- @WithSpan / @SpanAttribute annotations, recognised by the Java agent.
         No SDK dependency: the agent supplies the implementation at runtime. -->
    <dependency>
      <groupId>io.opentelemetry.instrumentation</groupId>
      <artifactId>opentelemetry-instrumentation-annotations</artifactId>
      <version>${opentelemetry.instrumentation.version}</version>
    </dependency>
{% else %}
    <dependency>
      <groupId>io.opentelemetry</groupId>
      <artifactId>opentelemetry-sdk</artifactId>
    </dependency>
{% if spec.protocol != 'console' %}
    <!-- One artifact covers both OTLP transports; the builder you call decides
         whether it is gRPC or HTTP/protobuf. -->
    <dependency>
      <groupId>io.opentelemetry</groupId>
      <artifactId>opentelemetry-exporter-otlp</artifactId>
    </dependency>
{% else %}
    <dependency>
      <groupId>io.opentelemetry</groupId>
      <artifactId>opentelemetry-exporter-logging</artifactId>
    </dependency>
{% endif %}
    <!-- Generated semantic-convention constants (ServiceAttributes and friends). -->
    <dependency>
      <groupId>io.opentelemetry.semconv</groupId>
      <artifactId>opentelemetry-semconv</artifactId>
      <version>1.29.0-alpha</version>
    </dependency>
{% endif %}
  </dependencies>
</project>
