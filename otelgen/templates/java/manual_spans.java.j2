package com.example.otel;

import io.opentelemetry.api.common.AttributeKey;
import io.opentelemetry.api.trace.Span;
import io.opentelemetry.api.trace.StatusCode;
import io.opentelemetry.instrumentation.annotations.SpanAttribute;
import io.opentelemetry.instrumentation.annotations.WithSpan;

/**
 * Manual spans for {{ service_name }}, on top of what the Java agent already
 * produces automatically.
 *
 * <p>The agent gives you a span per HTTP request, per JDBC statement and per
 * outbound call. What it cannot know is your domain: which step of the checkout
 * this is, which tenant it belongs to, why it was slow. That is what these
 * spans and attributes are for.
 *
 * <p>{@code @WithSpan} is recognised by the agent at runtime; the
 * {@code opentelemetry-instrumentation-annotations} artifact only supplies the
 * annotation itself, not an implementation, so it adds no SDK dependency.
 *
 * <p>Generated by {{ generator }}.
 * <br>Background reading: {{ article }}
 */
public final class BusinessSpans {

  private static final AttributeKey<String> ORDER_ID = AttributeKey.stringKey("order.id");
  private static final AttributeKey<Long> ITEM_COUNT = AttributeKey.longKey("order.item_count");

  private BusinessSpans() {}

  /**
   * A span named "reserveInventory" is created around this method, as a child
   * of whatever the agent has already put on the current context.
   */
  @WithSpan("reserveInventory")
  public void reserveInventory(@SpanAttribute("order.id") String orderId, int itemCount) {
    // Span.current() is the span the annotation just created.
    Span span = Span.current();
    span.setAttribute(ITEM_COUNT, itemCount);

    try {
      doReserve(orderId, itemCount);
    } catch (RuntimeException e) {
      // Without both of these the span looks successful in the UI and the
      // failure is invisible until someone reads the logs.
      span.recordException(e);
      span.setStatus(StatusCode.ERROR, e.getMessage());
      throw e;
    }
  }

  /**
   * The same thing without annotations, for code paths where you need control
   * over the span's lifetime. {@code makeCurrent()} is what puts the span on
   * the context so nested work becomes a child; forgetting it produces spans
   * with no parent.
   */
  public void reserveInventoryExplicitly(String orderId, int itemCount) {
    Span span =
        io.opentelemetry.api.GlobalOpenTelemetry.getTracer("{{ service_name }}", "{{ service_version }}")
            .spanBuilder("reserveInventory")
            .setAttribute(ORDER_ID, orderId)
            .setAttribute(ITEM_COUNT, itemCount)
            .startSpan();
    try (io.opentelemetry.context.Scope ignored = span.makeCurrent()) {
      doReserve(orderId, itemCount);
    } catch (RuntimeException e) {
      span.recordException(e);
      span.setStatus(StatusCode.ERROR, e.getMessage());
      throw e;
    } finally {
      // A span that is never ended is a span that is never exported.
      span.end();
    }
  }

  private void doReserve(String orderId, int itemCount) {
    if (itemCount <= 0) {
      throw new IllegalArgumentException("order " + orderId + " has no items");
    }
    // Replace with the real work.
  }
}
