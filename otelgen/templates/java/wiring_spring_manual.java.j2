package com.example.otel;

import io.opentelemetry.api.baggage.propagation.W3CBaggagePropagator;
import io.opentelemetry.api.common.AttributeKey;
import io.opentelemetry.api.common.Attributes;
import io.opentelemetry.api.trace.Tracer;
import io.opentelemetry.api.trace.propagation.W3CTraceContextPropagator;
import io.opentelemetry.context.propagation.ContextPropagators;
import io.opentelemetry.context.propagation.TextMapPropagator;
{% if spec.protocol == 'grpc' %}
import io.opentelemetry.exporter.otlp.trace.OtlpGrpcSpanExporter;
{% elif spec.protocol == 'http' %}
import io.opentelemetry.exporter.otlp.http.trace.OtlpHttpSpanExporter;
{% else %}
import io.opentelemetry.exporter.logging.LoggingSpanExporter;
{% endif %}
import io.opentelemetry.sdk.OpenTelemetrySdk;
import io.opentelemetry.sdk.resources.Resource;
import io.opentelemetry.sdk.trace.SdkTracerProvider;
import io.opentelemetry.sdk.trace.export.BatchSpanProcessor;
import io.opentelemetry.sdk.trace.export.SpanExporter;
import io.opentelemetry.sdk.trace.samplers.Sampler;
import io.opentelemetry.semconv.ServiceAttributes;
import java.time.Duration;
import org.springframework.beans.factory.annotation.Value;
import org.springframework.context.annotation.Bean;
import org.springframework.context.annotation.Configuration;

/**
 * Hand-built OpenTelemetry SDK for {{ service_name }}.
 *
 * <p>This is the alternative to the Java agent: you own the wiring, so you know
 * exactly what is installed, at the cost of instrumenting libraries yourself.
 * {@link TracingFilter} turns each HTTP request into a server span.
 *
 * <p>Exporter: {{ backend.label }}{% if spec.exports_to_collector %} via the local OpenTelemetry Collector{% endif %}.
 * <br>Sampling: {{ sampling.description }}.
 *
 * <p>Generated by {{ generator }}.
 * <br>Background reading: {{ article }}
 */
@Configuration
public class OpenTelemetryConfig {

  private static final AttributeKey<String> DEPLOYMENT_ENVIRONMENT_NAME =
      AttributeKey.stringKey("deployment.environment.name");
  private static final AttributeKey<String> DEPLOYMENT_ENVIRONMENT =
      AttributeKey.stringKey("deployment.environment");

  @Value("${OTEL_SERVICE_NAME:{{ service_name }}}")
  private String serviceName;

  @Value("${SERVICE_VERSION:{{ service_version }}}")
  private String serviceVersion;

  @Value("${DEPLOYMENT_ENVIRONMENT:{{ environment }}}")
  private String environment;
{% if spec.protocol != 'console' %}

  @Value("${OTEL_EXPORTER_OTLP_TRACES_ENDPOINT:{{ spec.traces_endpoint }}}")
  private String otlpEndpoint;
{% endif %}
{% for name, env_var in spec.headers %}

  @Value("${{ '${' }}{{ env_var }}:}")
  private String {{ env_var|camel }};
{% endfor %}

  /**
   * The SDK instance, registered globally so {@code GlobalOpenTelemetry} works
   * for code that cannot be injected. {@code destroyMethod = "close"} makes
   * Spring flush the batch processor on shutdown; without it the last few
   * seconds of spans are lost on every deploy.
   */
  @Bean(destroyMethod = "close")
  public OpenTelemetrySdk openTelemetry() {
    Resource resource =
        Resource.getDefault()
            .merge(
                Resource.create(
                    Attributes.builder()
                        .put(ServiceAttributes.SERVICE_NAME, serviceName)
                        .put(ServiceAttributes.SERVICE_VERSION, serviceVersion)
                        // Both spellings: the current semantic convention and
                        // the older one many backends still index on.
                        .put(DEPLOYMENT_ENVIRONMENT_NAME, environment)
                        .put(DEPLOYMENT_ENVIRONMENT, environment)
                        .build()));

    SdkTracerProvider tracerProvider =
        SdkTracerProvider.builder()
            .setResource(resource)
            .setSampler(sampler())
            .addSpanProcessor(
                BatchSpanProcessor.builder(spanExporter())
                    .setScheduleDelay(Duration.ofSeconds(5))
                    .setMaxQueueSize(2048)
                    .setMaxExportBatchSize(512)
                    .setExporterTimeout(Duration.ofSeconds(30))
                    .build())
            .build();

    return OpenTelemetrySdk.builder()
        .setTracerProvider(tracerProvider)
        // W3C trace context plus W3C baggage. Register both: baggage does not
        // cross a process boundary without its own propagator.
        .setPropagators(
            ContextPropagators.create(
                TextMapPropagator.composite(
                    W3CTraceContextPropagator.getInstance(),
                    W3CBaggagePropagator.getInstance())))
        .buildAndRegisterGlobal();
  }

  @Bean
  public Tracer tracer(OpenTelemetrySdk openTelemetry) {
    return openTelemetry.getTracer("{{ service_name }}", "{{ service_version }}");
  }

  /** Sampling policy: {{ sampling.description }}. */
  private Sampler sampler() {
{% if sampling.kind == 'head' %}
    // Only root spans consult the ratio; children follow the parent's
    // decision, so a trace is never recorded in one service and dropped in the
    // next.
    return Sampler.parentBased(Sampler.traceIdRatioBased({{ '%.4g'|format(sampling.ratio) }}));
{% elif sampling.kind == 'always_on' %}
    return Sampler.alwaysOn();
{% elif sampling.kind == 'always_off' %}
    return Sampler.alwaysOff();
{% else %}
    return Sampler.parentBased(Sampler.alwaysOn());
{% endif %}
  }

  /** Span exporter for {{ backend.label }}. */
  private SpanExporter spanExporter() {
{% if spec.protocol == 'grpc' %}
    return OtlpGrpcSpanExporter.builder()
        .setEndpoint(otlpEndpoint)
{% for name, env_var in spec.headers %}
        .addHeader("{{ name }}", {{ env_var|camel }})
{% endfor %}
        .setTimeout(Duration.ofSeconds(10))
        .build();
{% elif spec.protocol == 'http' %}
    return OtlpHttpSpanExporter.builder()
        .setEndpoint(otlpEndpoint)
{% for name, env_var in spec.headers %}
        .addHeader("{{ name }}", {{ env_var|camel }})
{% endfor %}
        .setTimeout(Duration.ofSeconds(10))
        .build();
{% else %}
    // Writes spans to the application log. No network, no credentials.
    return LoggingSpanExporter.create();
{% endif %}
  }
}
