package com.example.otel;

import io.opentelemetry.context.Context;
import java.util.concurrent.ExecutorService;
import java.util.concurrent.Executors;
import java.util.concurrent.ScheduledExecutorService;

/**
 * Context-propagating executors for {{ service_name }}.
 *
 * <p>{@code Context} is held in a thread local. Hand a task to a thread pool
 * and the worker thread sees an empty context, so any span it creates has no
 * parent and shows up as a separate, orphaned trace. This is the single most
 * common way traces break in a Java service.
 *
 * <p>{@code Context.taskWrapping} fixes it by capturing the submitting thread's
 * context and reinstating it inside the worker. Wrap the pool once, at the
 * point you create it, and every task submitted to it is covered:
 *
 * <pre>{@code
 * @Bean
 * public ExecutorService applicationExecutor() {
 *   return TracedExecutors.fixedPool(8);
 * }
 * }</pre>
 *
 * <p>The same applies to {@code CompletableFuture}: pass a wrapped executor
 * explicitly, because the default {@code ForkJoinPool.commonPool()} is not
 * wrapped.
 *
 * <p>Generated by {{ generator }}.
 * <br>Background reading: {{ article }}
 */
public final class TracedExecutors {

  private TracedExecutors() {}

  /** A fixed thread pool that carries the caller's context into each task. */
  public static ExecutorService fixedPool(int threads) {
    return Context.taskWrapping(Executors.newFixedThreadPool(threads));
  }

  /** Wraps an executor you already have. */
  public static ExecutorService wrap(ExecutorService delegate) {
    return Context.taskWrapping(delegate);
  }

  /**
   * Scheduled pools need the same treatment, with one caveat: a task scheduled
   * once and repeated forever would keep the original trace context alive
   * across every execution. For repeating work, capture the context inside the
   * task instead of wrapping the pool.
   */
  public static ScheduledExecutorService scheduledPool(int threads) {
    return Executors.newScheduledThreadPool(threads);
  }

  /**
   * Explicit form, for a single task handed to a pool you do not control.
   *
   * <pre>{@code
   * unwrappedPool.submit(TracedExecutors.withCurrentContext(() -> doWork()));
   * }</pre>
   */
  public static Runnable withCurrentContext(Runnable task) {
    return Context.current().wrap(task);
  }
}
