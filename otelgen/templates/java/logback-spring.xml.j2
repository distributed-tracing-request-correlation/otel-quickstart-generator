<?xml version="1.0" encoding="UTF-8"?>
<!--
  Logging with trace-ID correlation for {{ service_name }}.

  Every line carries the active trace and span ID, so a log line can be pasted
  into {{ backend.label }} to retrieve the trace it belongs to.

{% if framework.key == 'spring-boot-agent' %}
  The Java agent populates the `trace_id`, `span_id` and `trace_flags` MDC keys
  automatically (its logback-mdc instrumentation is on by default), so nothing
  in the application has to set them.
{% else %}
  `TracingFilter` puts `trace_id` and `span_id` into the MDC for the duration of
  each request; the `:-` default keeps the pattern readable outside a request.
{% endif %}

  Generated by {{ generator }}.
  Background reading: {{ article }}
-->
<configuration>
  <property name="SERVICE_NAME" value="{{ service_name }}"/>

  <appender name="CONSOLE" class="ch.qos.logback.core.ConsoleAppender">
    <encoder>
      <pattern>%d{yyyy-MM-dd'T'HH:mm:ss.SSSXXX} %-5level [${SERVICE_NAME},%X{trace_id:-},%X{span_id:-}] %logger{40} - %msg%n</pattern>
    </encoder>
  </appender>

  <!--
    Structured alternative. Add net.logstash.logback:logstash-logback-encoder
    to the build, then swap the encoder above for this one: MDC entries become
    top-level JSON fields, which is what a log store wants to index.

    <appender name="JSON" class="ch.qos.logback.core.ConsoleAppender">
      <encoder class="net.logstash.logback.encoder.LogstashEncoder">
        <includeMdcKeyName>trace_id</includeMdcKeyName>
        <includeMdcKeyName>span_id</includeMdcKeyName>
        <customFields>{"service.name":"{{ service_name }}"}</customFields>
      </encoder>
    </appender>
  -->

  <root level="INFO">
    <appender-ref ref="CONSOLE"/>
  </root>

  <logger name="io.opentelemetry" level="INFO"/>
</configuration>
