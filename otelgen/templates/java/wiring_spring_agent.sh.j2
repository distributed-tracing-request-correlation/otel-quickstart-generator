#!/usr/bin/env bash
#
# Run {{ service_name }} with the OpenTelemetry Java agent.
#
# The agent instruments Spring MVC/WebFlux, JDBC, the HTTP clients, Kafka and
# roughly a hundred other libraries without a line of application code. It is
# configured entirely through environment variables and -D system properties.
#
# Generated by {{ generator }}.
# Background reading: {{ article }}

set -euo pipefail

cd "$(dirname "$0")"

AGENT_JAR="${AGENT_JAR:-opentelemetry-javaagent.jar}"
AGENT_VERSION="${AGENT_VERSION:-v2.13.3}"
AGENT_URL="https://github.com/open-telemetry/opentelemetry-java-instrumentation/releases/download/${AGENT_VERSION}/opentelemetry-javaagent.jar"
APP_JAR="${APP_JAR:-target/{{ service_name }}.jar}"

if [ ! -f "${AGENT_JAR}" ]; then
  echo "downloading OpenTelemetry Java agent ${AGENT_VERSION}"
  curl -fsSL -o "${AGENT_JAR}" "${AGENT_URL}"
fi

if [ ! -f "${APP_JAR}" ]; then
  echo "application jar not found at ${APP_JAR}; run 'mvn package' first" >&2
  echo "or set APP_JAR=/path/to/your.jar" >&2
  exit 1
fi

# ---------------------------------------------------------------------------
# Identity. service.name is the single most important attribute you will set:
# it is how every backend groups spans into a service.
# ---------------------------------------------------------------------------
export OTEL_SERVICE_NAME="${OTEL_SERVICE_NAME:-{{ service_name }}}"
export OTEL_RESOURCE_ATTRIBUTES="${OTEL_RESOURCE_ATTRIBUTES:-service.version={{ service_version }},deployment.environment.name={{ environment }},deployment.environment={{ environment }}}"

# ---------------------------------------------------------------------------
# Export. Metrics and logs are disabled here so the agent only emits traces;
# drop the two `none` lines when you want the other signals as well.
# ---------------------------------------------------------------------------
export OTEL_METRICS_EXPORTER="${OTEL_METRICS_EXPORTER:-none}"
export OTEL_LOGS_EXPORTER="${OTEL_LOGS_EXPORTER:-none}"
{% if spec.protocol == 'console' %}
export OTEL_TRACES_EXPORTER="${OTEL_TRACES_EXPORTER:-logging}"
{% else %}
export OTEL_TRACES_EXPORTER="${OTEL_TRACES_EXPORTER:-otlp}"
{% if spec.protocol == 'http' %}
export OTEL_EXPORTER_OTLP_PROTOCOL="${OTEL_EXPORTER_OTLP_PROTOCOL:-http/protobuf}"
{% else %}
export OTEL_EXPORTER_OTLP_PROTOCOL="${OTEL_EXPORTER_OTLP_PROTOCOL:-grpc}"
{% endif %}
# The agent appends the signal path (/v1/traces) itself, so this is the base URL.
export OTEL_EXPORTER_OTLP_ENDPOINT="${OTEL_EXPORTER_OTLP_ENDPOINT:-{{ spec.endpoint }}}"
{% for name, env_var in spec.headers %}
if [ -n "${{ '{' }}{{ env_var }}:-}" ]; then
  export OTEL_EXPORTER_OTLP_HEADERS="{{ name }}=${{ '{' }}{{ env_var }}}"
fi
{% endfor %}
{% endif %}

# ---------------------------------------------------------------------------
# Propagation and sampling.
# ---------------------------------------------------------------------------
export OTEL_PROPAGATORS="${OTEL_PROPAGATORS:-tracecontext,baggage}"
export OTEL_TRACES_SAMPLER="${OTEL_TRACES_SAMPLER:-{{ sampling.otel_traces_sampler }}}"
{% if sampling.otel_traces_sampler_arg %}
export OTEL_TRACES_SAMPLER_ARG="${OTEL_TRACES_SAMPLER_ARG:-{{ sampling.otel_traces_sampler_arg }}}"
{% endif %}

# Batch span processor. The defaults are sensible; these are the knobs you will
# reach for first if the agent logs dropped spans under load.
export OTEL_BSP_SCHEDULE_DELAY="${OTEL_BSP_SCHEDULE_DELAY:-5000}"
export OTEL_BSP_MAX_QUEUE_SIZE="${OTEL_BSP_MAX_QUEUE_SIZE:-2048}"
export OTEL_BSP_MAX_EXPORT_BATCH_SIZE="${OTEL_BSP_MAX_EXPORT_BATCH_SIZE:-512}"

# Health endpoints are polled constantly and their spans carry no information.
JAVA_TOOL_ARGS=(
  "-javaagent:${AGENT_JAR}"
  "-Dotel.instrumentation.common.default-enabled=true"
  "-Dotel.instrumentation.spring-webmvc.enabled=true"
)

exec java "${JAVA_TOOL_ARGS[@]}" -jar "${APP_JAR}" "$@"
