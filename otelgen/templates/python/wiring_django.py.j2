"""Django instrumentation wiring for {{ service_name }}.

Django decides its middleware stack at import time, so tracing has to be
configured before ``django.setup()`` runs. The dependable place is the very top
of ``wsgi.py`` / ``asgi.py`` (and ``manage.py`` for management commands)::

    # wsgi.py
    import os

    os.environ.setdefault("DJANGO_SETTINGS_MODULE", "myproject.settings")

    from otel import configure_logging, configure_tracing
    from otel.instrumentation import instrument

    configure_tracing()
    configure_logging()
    instrument()

    from django.core.wsgi import get_wsgi_application  # noqa: E402

    application = get_wsgi_application()

Under Gunicorn with preloading or multiple workers, call ``configure_tracing()``
again in a ``post_fork`` hook: the batch span processor's exporter thread does
not survive ``fork()``.

Generated by {{ generator }}.
Background reading: {{ article }}
"""

from __future__ import annotations

import logging

from opentelemetry.instrumentation.django import DjangoInstrumentor
from opentelemetry.instrumentation.requests import RequestsInstrumentor

logger = logging.getLogger(__name__)

EXCLUDED_URLS = "health,healthz,readyz,livez,metrics"


def instrument() -> None:
    """Install Django and outbound-HTTP instrumentation.

    ``DjangoInstrumentor`` inserts its middleware at the top of the stack, so
    the server span covers every other middleware as well.
    """
    DjangoInstrumentor().instrument(
        excluded_urls=EXCLUDED_URLS,
        # Span names use the resolved URL pattern, not the concrete path.
        is_sql_commentor_enabled=False,
    )
    RequestsInstrumentor().instrument()
    logger.info("opentelemetry instrumentation installed for Django")


def instrument_gunicorn_post_fork(server, worker) -> None:  # noqa: ANN001
    """Gunicorn ``post_fork`` hook.

    Add to ``gunicorn.conf.py``::

        from otel.instrumentation import instrument_gunicorn_post_fork as post_fork
    """
    from otel.tracing import configure_tracing

    configure_tracing(force=True)
    logger.info("re-initialised tracer provider in worker pid=%s", worker.pid)


def uninstrument() -> None:
    """Remove instrumentation. Mostly useful in tests."""
    DjangoInstrumentor().uninstrument()
    RequestsInstrumentor().uninstrument()
