"""Celery worker instrumentation wiring for {{ service_name }}.

Celery prefork workers ``fork()`` after the module is imported. A tracer
provider created in the parent has a background export thread that does not
survive the fork, and its spans are silently lost. Both hooks below run *inside*
the child, which is the only safe place to build the provider.

Usage in your Celery app module::

    from celery import Celery
    from otel.instrumentation import setup_worker_tracing

    app = Celery("{{ service_name }}", broker="redis://localhost:6379/0")
    setup_worker_tracing()

Producers (the web process enqueuing the task) need their own
``configure_tracing()`` call plus ``instrument()``; ``CeleryInstrumentor``
injects the ``traceparent`` into the task headers there, which is what links the
worker span to the request that queued it.

Generated by {{ generator }}.
Background reading: {{ article }}
"""

from __future__ import annotations

import logging

from celery.signals import worker_process_init, worker_process_shutdown
from opentelemetry.instrumentation.celery import CeleryInstrumentor
from opentelemetry.instrumentation.requests import RequestsInstrumentor

logger = logging.getLogger(__name__)


def instrument() -> None:
    """Instrument Celery in the current process.

    Call this directly in the *producer* (your web application), and let
    :func:`setup_worker_tracing` handle the worker side.
    """
    CeleryInstrumentor().instrument()
    RequestsInstrumentor().instrument()
    logger.info("opentelemetry instrumentation installed for Celery")


def setup_worker_tracing() -> None:
    """Register the per-worker-process fork hooks. Call once at import time."""
    worker_process_init.connect(_init_worker_tracing, weak=False)
    worker_process_shutdown.connect(_shutdown_worker_tracing, weak=False)


def _init_worker_tracing(*args, **kwargs) -> None:
    from otel.logging_setup import configure_logging
    from otel.tracing import configure_tracing

    configure_tracing(force=True)
    configure_logging()
    instrument()


def _shutdown_worker_tracing(*args, **kwargs) -> None:
    """Flush whatever is still queued before the child exits."""
    from otel.tracing import shutdown_tracing

    shutdown_tracing()


def uninstrument() -> None:
    """Remove instrumentation. Mostly useful in tests."""
    CeleryInstrumentor().uninstrument()
    RequestsInstrumentor().uninstrument()
