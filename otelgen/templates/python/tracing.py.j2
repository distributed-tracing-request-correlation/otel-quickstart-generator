"""OpenTelemetry tracing bootstrap for {{ service_name }}.

Call :func:`configure_tracing` exactly once, as early in process startup as
possible and before any instrumented library is imported and used.

Exporter: {{ backend.label }}{% if spec.exports_to_collector %} via the local OpenTelemetry Collector{% endif %}.
Sampling: {{ sampling.description }}.

Generated by {{ generator }}.
Background reading: {{ article }}
"""

from __future__ import annotations

import atexit
import os
{% if spec.protocol != 'console' %}
from typing import Any
{% endif %}

from opentelemetry import trace
from opentelemetry.baggage.propagation import W3CBaggagePropagator
from opentelemetry.propagate import set_global_textmap
from opentelemetry.propagators.composite import CompositePropagator
from opentelemetry.sdk.resources import Resource
from opentelemetry.sdk.trace import TracerProvider
from opentelemetry.sdk.trace.export import (
    BatchSpanProcessor,
{% if spec.protocol == 'console' %}
    ConsoleSpanExporter,
{% endif %}
    SpanExporter,
)
from opentelemetry.sdk.trace.sampling import (
{% if sampling.kind == 'always_off' %}
    ALWAYS_OFF,
{% endif %}
{% if sampling.kind in ('always_on', 'parentbased') %}
    ALWAYS_ON,
{% endif %}
{% if sampling.kind in ('head', 'parentbased') %}
    ParentBased,
{% endif %}
    Sampler,
{% if sampling.kind == 'head' %}
    TraceIdRatioBased,
{% endif %}
)
from opentelemetry.trace.propagation.tracecontext import TraceContextTextMapPropagator
{% if spec.protocol == 'grpc' %}
from opentelemetry.exporter.otlp.proto.grpc.trace_exporter import OTLPSpanExporter
{% elif spec.protocol == 'http' %}
from opentelemetry.exporter.otlp.proto.http.trace_exporter import OTLPSpanExporter
{% endif %}

SERVICE_NAME = os.getenv("OTEL_SERVICE_NAME", "{{ service_name }}")
SERVICE_VERSION = os.getenv("SERVICE_VERSION", "{{ service_version }}")
DEPLOYMENT_ENVIRONMENT = os.getenv("DEPLOYMENT_ENVIRONMENT", "{{ environment }}")
{% if spec.protocol != 'console' %}
OTLP_ENDPOINT = os.getenv(
    "OTEL_EXPORTER_OTLP_TRACES_ENDPOINT", "{{ spec.traces_endpoint }}"
)
{% endif %}

_provider: TracerProvider | None = None


def _build_resource() -> Resource:
    """Identity of this process, attached to every span it produces.

    ``Resource.create`` also merges anything found in the
    ``OTEL_RESOURCE_ATTRIBUTES`` environment variable, so deployment-specific
    attributes can be added without a code change.
    """
    return Resource.create(
        {
            "service.name": SERVICE_NAME,
            "service.version": SERVICE_VERSION,
            # Both spellings are emitted: the newer semantic convention and the
            # older one many backends still index on.
            "deployment.environment.name": DEPLOYMENT_ENVIRONMENT,
            "deployment.environment": DEPLOYMENT_ENVIRONMENT,
        }
    )


def _build_sampler() -> Sampler:
{% if sampling.kind == 'head' %}
    """Head-based sampling: keep {{ '%.4g'|format(sampling.ratio) }} of root traces.

    ``ParentBased`` guarantees the decision made by the caller is honoured, so a
    trace is never half-recorded across services. Only root spans consult the
    ratio.
    """
    ratio = float(os.getenv("OTEL_TRACES_SAMPLER_ARG", "{{ '%.4g'|format(sampling.ratio) }}"))
    return ParentBased(root=TraceIdRatioBased(ratio))
{% elif sampling.kind == 'always_on' %}
    """Record every trace. Fine for development and low-traffic services."""
    return ALWAYS_ON
{% elif sampling.kind == 'always_off' %}
    """Record nothing locally; useful when a tail sampler decides downstream."""
    return ALWAYS_OFF
{% else %}
    """Honour the caller's decision; sample every trace that starts here."""
    return ParentBased(root=ALWAYS_ON)
{% endif %}


def _build_exporter() -> SpanExporter:
{% if spec.protocol == 'console' %}
    """Print spans to stdout as JSON. No network, no backend, no credentials."""
    return ConsoleSpanExporter()
{% else %}
    """Export over OTLP/{{ spec.protocol_label }} to {{ backend.label }}."""
{% if spec.headers %}
    headers: dict[str, str] = {}
{% for name, env_var in spec.headers %}
    if os.getenv("{{ env_var }}"):
        headers["{{ name }}"] = os.environ["{{ env_var }}"]
{% endfor %}
{% else %}
    headers: dict[str, str] = {}
{% endif %}
    kwargs: dict[str, Any] = {"endpoint": OTLP_ENDPOINT, "timeout": 10}
    if headers:
        kwargs["headers"] = headers
{% if spec.protocol == 'grpc' %}
    # Plaintext is only acceptable because the endpoint is a loopback collector.
    kwargs["insecure"] = OTLP_ENDPOINT.startswith("http://")
{% endif %}
    return OTLPSpanExporter(**kwargs)
{% endif %}


def configure_tracing(force: bool = False) -> TracerProvider:
    """Install the global tracer provider and propagators. Idempotent.

    Returns the provider so callers can flush or shut it down explicitly.
    """
    global _provider
    if _provider is not None and not force:
        return _provider

    provider = TracerProvider(resource=_build_resource(), sampler=_build_sampler())
    provider.add_span_processor(
        BatchSpanProcessor(
            _build_exporter(),
            # Defaults tuned for a service that emits steadily rather than in
            # bursts; raise max_queue_size if you see dropped spans in the logs.
            max_queue_size=2048,
            schedule_delay_millis=5000,
            max_export_batch_size=512,
            export_timeout_millis=30000,
        )
    )
    trace.set_tracer_provider(provider)

    # W3C traceparent/tracestate plus W3C baggage, in that order. Without the
    # baggage propagator, baggage set in this process never leaves it.
    set_global_textmap(
        CompositePropagator(
            [TraceContextTextMapPropagator(), W3CBaggagePropagator()]
        )
    )

    atexit.register(shutdown_tracing)
    _provider = provider
    return provider


def shutdown_tracing() -> None:
    """Flush queued spans and stop the exporter.

    Registered with ``atexit`` by :func:`configure_tracing`; call it directly
    from a framework shutdown hook when you want the flush to happen earlier.
    """
    global _provider
    if _provider is None:
        return
    provider, _provider = _provider, None
    provider.shutdown()


def get_tracer(name: str = "{{ service_name }}") -> trace.Tracer:
    """Tracer handle for manual spans."""
    return trace.get_tracer(name, "{{ service_version }}")
