from __future__ import annotations

import logging
from typing import Any

from opentelemetry.instrumentation.flask import FlaskInstrumentor
from opentelemetry.instrumentation.requests import RequestsInstrumentor

logger = logging.getLogger(__name__)

EXCLUDED_URLS = "health,healthz,readyz,livez,metrics"


def instrument(app: Any) -> Any:
    """Instrument a Flask application and the outbound HTTP client."""
    FlaskInstrumentor().instrument_app(
        app,
        excluded_urls=EXCLUDED_URLS,
        request_hook=_request_hook,
    )
    RequestsInstrumentor().instrument()
    logger.info("opentelemetry instrumentation installed for Flask")
    return app


def _request_hook(span: Any, environ: dict) -> None:
    """Attach the matched rule so span names stay low-cardinality."""
    if span is None or not span.is_recording():
        return
    rule = environ.get("werkzeug.request")
    if rule is not None and getattr(rule, "url_rule", None) is not None:
        span.set_attribute("http.route", str(rule.url_rule))


def uninstrument(app: Any) -> None:
    """Remove instrumentation. Mostly useful in tests."""
    FlaskInstrumentor().uninstrument_app(app)
    RequestsInstrumentor().uninstrument()
