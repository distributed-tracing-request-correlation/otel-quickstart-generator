# OpenTelemetry Collector configuration for {{ service_name }}.
#
# The collector sits between {{ service_name }} and {{ backend.label }}. It is
# worth the extra hop: the application gets to fire spans at localhost and
# forget about them, while retries, batching, backend credentials and any
# redaction happen here, where they can be changed without a redeploy.
#
# Processor order in a pipeline is the order below, and it matters:
# memory_limiter first so it can reject before memory is spent, batch last so
# everything upstream sees individual spans.
#
# Generated by {{ generator }}.
# Background reading: {{ article }}

receivers:
  otlp:
    protocols:
      grpc:
        endpoint: 0.0.0.0:4317
      http:
        endpoint: 0.0.0.0:4318
        # Browsers need this for OTLP/HTTP from a frontend SDK.
        cors:
          allowed_origins:
            - http://localhost:*

processors:
  # Refuses new data before the process runs out of memory. Without it, a
  # backend outage turns into a collector OOM kill and you lose everything.
  memory_limiter:
    check_interval: 1s
    limit_percentage: 80
    spike_limit_percentage: 20

  # Adds identity for spans that arrive without it.
  resource:
    attributes:
      - key: collector.name
        value: {{ service_name }}-collector
        action: insert
      - key: deployment.environment.name
        value: {{ environment }}
        action: insert

  # Always last. Batching is what makes export efficient; a collector without
  # it does one network round trip per span.
  batch:
    send_batch_size: 8192
    send_batch_max_size: 10000
    timeout: 5s

exporters:
{% if backend.key == 'jaeger' %}
  otlp/jaeger:
    endpoint: jaeger:4317
    tls:
      insecure: true
{% elif backend.key == 'tempo' %}
  otlp/tempo:
    endpoint: tempo:4317
    tls:
      insecure: true
{% elif backend.key == 'datadog' %}
  # The Datadog Agent's own OTLP receiver; the agent forwards to the platform.
  otlp/datadog:
    endpoint: datadog-agent:4317
    tls:
      insecure: true
{% elif backend.key == 'honeycomb' %}
  otlp/honeycomb:
    endpoint: api.honeycomb.io:443
    headers:
      x-honeycomb-team: ${env:HONEYCOMB_API_KEY}
{% elif backend.key == 'otlp-http' %}
  # Point this at your OTLP/HTTP backend. Until then, spans are only printed by
  # the debug exporter below.
  otlphttp/backend:
    endpoint: ${env:UPSTREAM_OTLP_HTTP_ENDPOINT}
{% else %}
  # Point this at your OTLP/gRPC backend. Until then, spans are only printed by
  # the debug exporter below.
  otlp/backend:
    endpoint: ${env:UPSTREAM_OTLP_ENDPOINT}
    tls:
      insecure: true
{% endif %}

  # Prints a summary of every batch to the collector log. Keep it while you are
  # wiring things up, drop it in production: at verbosity: detailed it is
  # expensive and noisy.
  debug:
    verbosity: normal

extensions:
  health_check:
    endpoint: 0.0.0.0:13133

service:
  extensions: [health_check]
  pipelines:
    traces:
      receivers: [otlp]
      processors: [memory_limiter, resource, batch]
{% if backend.key == 'jaeger' %}
      exporters: [otlp/jaeger, debug]
{% elif backend.key == 'tempo' %}
      exporters: [otlp/tempo, debug]
{% elif backend.key == 'datadog' %}
      exporters: [otlp/datadog, debug]
{% elif backend.key == 'honeycomb' %}
      exporters: [otlp/honeycomb, debug]
{% elif backend.key == 'otlp-http' %}
      exporters: [otlphttp/backend, debug]
{% else %}
      exporters: [otlp/backend, debug]
{% endif %}
  telemetry:
    logs:
      level: info
