# Grafana Tempo configuration for the {{ service_name }} development stack.
#
# Single-binary Tempo with local-disk storage: every component runs in one
# process and blocks are written to a container volume. That is the right shape
# for a laptop and the wrong shape for production, where the backend is object
# storage and the components scale separately.
#
# Generated by {{ generator }}.
# Background reading: {{ article }}

stream_over_http_enabled: true

server:
  http_listen_port: 3200
  log_level: info

distributor:
  receivers:
    otlp:
      protocols:
        grpc:
          endpoint: 0.0.0.0:4317
        http:
          endpoint: 0.0.0.0:4318

ingester:
  # Short blocks so traces become searchable seconds after they arrive rather
  # than minutes. Production values are much larger.
  max_block_duration: 5m
  complete_block_timeout: 15m

compactor:
  compaction:
    block_retention: 24h

querier:
  max_concurrent_queries: 20

storage:
  trace:
    backend: local
    wal:
      path: /var/tempo/wal
    local:
      path: /var/tempo/blocks
    pool:
      max_workers: 20
      queue_depth: 2000

usage_report:
  reporting_enabled: false
