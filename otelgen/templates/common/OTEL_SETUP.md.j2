Copy the `tracing/` package into your module and call `Setup` from `main`:

```go
func main() {
	ctx := context.Background()

	shutdown, err := tracing.Setup(ctx)
	if err != nil {
		log.Fatalf("tracing setup: %v", err)
	}
	defer func() {
		ctx, cancel := context.WithTimeout(context.Background(), 5*time.Second)
		defer cancel()
		if err := shutdown(ctx); err != nil {
			log.Printf("tracing shutdown: %v", err)
		}
	}()

	slog.SetDefault(tracing.NewLogger())
{% if framework.key == 'net-http' %}

	mux := http.NewServeMux()
	mux.HandleFunc("GET /orders/{id}", getOrder)

	srv := &http.Server{Addr: ":8080", Handler: tracing.Handler(mux)}
	log.Fatal(srv.ListenAndServe())
{% else %}

	srv := grpc.NewServer(tracing.ServerOptions()...)
	// register your services on srv
	log.Fatal(srv.Serve(listener))
{% endif %}
}
```

Deferring `shutdown` is not optional: without it the last batch of spans is
still in memory when the process exits.
