# Grafana data source provisioning for the {{ service_name }} stack.
#
# Grafana reads this at startup, so Tempo is queryable the moment the stack is
# up: open http://localhost:3000, Explore, then search by service name or paste
# a trace ID.
#
# `tracesToLogsV2` is the interesting part. It is what turns a span into a link
# to the logs emitted during that span, provided your log lines carry the
# trace ID and you add a Loki data source with the matching uid.
#
# Generated by {{ generator }}.
# Background reading: {{ article }}

apiVersion: 1

datasources:
  - name: Tempo
    type: tempo
    uid: tempo
    access: proxy
    url: http://tempo:3200
    isDefault: true
    editable: true
    jsonData:
      httpMethod: GET
      # Enable once a Loki data source with uid "loki" exists.
      # tracesToLogsV2:
      #   datasourceUid: loki
      #   spanStartTimeShift: -1h
      #   spanEndTimeShift: 1h
      #   filterByTraceID: true
      #   tags:
      #     - key: service.name
      #       value: service_name
      nodeGraph:
        enabled: true
      search:
        hide: false
      tracesToMetrics:
        datasourceUid: ""
