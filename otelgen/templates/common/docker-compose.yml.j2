# Local tracing stack for {{ service_name }}: {% if spec.with_collector %}an OpenTelemetry Collector{% if backend.compose_services %} plus {{ backend.label }}{% endif %}{% else %}{{ backend.label }}{% endif %}.
#
#   docker compose up -d
#
# {{ service_name }} itself stays outside the stack and sends spans to
# {{ spec.endpoint }} on the host.
{% if backend.ui %}
# Traces land in {{ backend.label }}: {{ backend.ui }}
{% endif %}
#
# Generated by {{ generator }}.
# Background reading: {{ article }}

name: {{ service_name }}-tracing

services:
{% if spec.with_collector %}
  otel-collector:
    image: otel/opentelemetry-collector-contrib:0.117.0
    container_name: {{ service_name }}-collector
    command: ["--config=/etc/otelcol/config.yaml"]
    volumes:
      - ./otel-collector-config.yaml:/etc/otelcol/config.yaml:ro
    ports:
      - "4317:4317"   # OTLP/gRPC
      - "4318:4318"   # OTLP/HTTP
      - "13133:13133" # health check
{% if backend.extra_env or backend.key in ('otlp-grpc', 'otlp-http') %}
    env_file:
      - .env
{% endif %}
{% if backend.compose_services %}
    depends_on:
{% for service in backend.compose_services %}
{% if service != 'grafana' %}
      - {{ service }}
{% endif %}
{% endfor %}
{% endif %}
    healthcheck:
      test: ["CMD", "/otelcol-contrib", "--help"]
      interval: 10s
      timeout: 5s
      retries: 3
    restart: unless-stopped

{% endif %}
{% if backend.key == 'jaeger' %}
  jaeger:
    image: jaegertracing/all-in-one:1.65.0
    container_name: {{ service_name }}-jaeger
    environment:
      # Native OTLP ingest. The old jaeger-thrift and jaeger-grpc exporters are
      # gone from the SDKs; OTLP is the only supported path in.
      - COLLECTOR_OTLP_ENABLED=true
      - SPAN_STORAGE_TYPE=memory
      # In-memory storage: fine for development, erased on restart.
      - MEMORY_MAX_TRACES=50000
    ports:
      - "16686:16686" # Jaeger UI
{% if not spec.with_collector %}
      - "4317:4317"   # OTLP/gRPC
      - "4318:4318"   # OTLP/HTTP
{% endif %}
    restart: unless-stopped

{% elif backend.key == 'tempo' %}
  tempo:
    image: grafana/tempo:2.7.0
    container_name: {{ service_name }}-tempo
    command: ["-config.file=/etc/tempo/tempo.yaml"]
    user: "0:0"
    volumes:
      - ./tempo.yaml:/etc/tempo/tempo.yaml:ro
      - tempo-data:/var/tempo
    ports:
      - "3200:3200"   # Tempo HTTP API, queried by Grafana
{% if not spec.with_collector %}
      - "4317:4317"   # OTLP/gRPC
{% endif %}
    restart: unless-stopped

  grafana:
    image: grafana/grafana:11.5.1
    container_name: {{ service_name }}-grafana
    environment:
      - GF_AUTH_ANONYMOUS_ENABLED=true
      - GF_AUTH_ANONYMOUS_ORG_ROLE=Admin
      - GF_AUTH_DISABLE_LOGIN_FORM=true
      - GF_FEATURE_TOGGLES_ENABLE=traceqlEditor
    volumes:
      - ./grafana/provisioning:/etc/grafana/provisioning:ro
      - grafana-data:/var/lib/grafana
    ports:
      - "3000:3000"   # Grafana, with Tempo pre-provisioned as a data source
    depends_on:
      - tempo
    restart: unless-stopped

{% elif backend.key == 'datadog' %}
  datadog-agent:
    image: gcr.io/datadoghq/agent:7
    container_name: {{ service_name }}-datadog-agent
    environment:
      - DD_API_KEY=${DD_API_KEY:?set DD_API_KEY in .env}
      - DD_SITE=${DD_SITE:-datadoghq.com}
      - DD_APM_ENABLED=true
      # The agent's own OTLP receiver. Spans arrive as OTLP and are converted
      # to Datadog's format inside the agent.
      - DD_OTLP_CONFIG_RECEIVER_PROTOCOLS_GRPC_ENDPOINT=0.0.0.0:4317
      - DD_OTLP_CONFIG_RECEIVER_PROTOCOLS_HTTP_ENDPOINT=0.0.0.0:4318
      - DD_HOSTNAME={{ service_name }}-local
    ports:
{% if not spec.with_collector %}
      - "4317:4317"   # OTLP/gRPC
      - "4318:4318"   # OTLP/HTTP
{% endif %}
      - "8126:8126"   # Datadog APM intake, for the tracer libraries
    restart: unless-stopped

{% endif %}
{% if backend.key == 'tempo' %}
volumes:
  tempo-data:
  grafana-data:
{% endif %}
