# Environment variables for {{ service_name }} ({{ lang.label }} / {{ framework.label }}).
# Copy to .env and adjust. Every OTEL_* variable below is read by the SDK
# itself, so it overrides what the generated bootstrap code hard-codes.
#
# Generated by {{ generator }}.
# Background reading: {{ article }}

# --- Identity -------------------------------------------------------------
# service.name is the attribute every backend groups spans by. Get it wrong and
# your service either disappears or merges with another one.
OTEL_SERVICE_NAME={{ service_name }}
SERVICE_VERSION={{ service_version }}
DEPLOYMENT_ENVIRONMENT={{ environment }}
# Anything extra, as comma-separated key=value pairs. Merged into the resource.
OTEL_RESOURCE_ATTRIBUTES=service.namespace=default,service.instance.id=${HOSTNAME}

# --- Export ---------------------------------------------------------------
{% if spec.protocol == 'console' %}
# Console exporter: spans are printed to stdout, nothing leaves the process.
OTEL_TRACES_EXPORTER=console
{% else %}
OTEL_TRACES_EXPORTER=otlp
{% if spec.protocol == 'grpc' %}
OTEL_EXPORTER_OTLP_PROTOCOL=grpc
{% else %}
OTEL_EXPORTER_OTLP_PROTOCOL=http/protobuf
{% endif %}
# Base endpoint. SDKs append the signal path (/v1/traces) to this one.
OTEL_EXPORTER_OTLP_ENDPOINT={{ spec.endpoint }}
# Signal-specific endpoint, used verbatim. Set only one of the two.
OTEL_EXPORTER_OTLP_TRACES_ENDPOINT={{ spec.traces_endpoint }}
{% endif %}
# Traces only. Set to otlp once you are ready for metrics and logs as well.
OTEL_METRICS_EXPORTER=none
OTEL_LOGS_EXPORTER=none

# --- Propagation ----------------------------------------------------------
# W3C trace context plus W3C baggage. Add b3multi only while migrating from a
# Zipkin-era deployment that still emits X-B3-* headers.
OTEL_PROPAGATORS=tracecontext,baggage

# --- Sampling -------------------------------------------------------------
# {{ sampling.description }}
OTEL_TRACES_SAMPLER={{ sampling.otel_traces_sampler }}
{% if sampling.otel_traces_sampler_arg %}
OTEL_TRACES_SAMPLER_ARG={{ sampling.otel_traces_sampler_arg }}
{% else %}
# OTEL_TRACES_SAMPLER_ARG=0.1   # only meaningful for the ratio samplers
{% endif %}

# --- Batch span processor -------------------------------------------------
# The first knobs to reach for when the SDK logs dropped spans under load.
OTEL_BSP_SCHEDULE_DELAY=5000
OTEL_BSP_MAX_QUEUE_SIZE=2048
OTEL_BSP_MAX_EXPORT_BATCH_SIZE=512

{% if backend.extra_env %}
# --- {{ backend.label }} ---
{% for name, value, comment in backend.extra_env %}
# {{ comment }}
{{ name }}={{ value }}
{% endfor %}

{% endif %}
# --- Application ----------------------------------------------------------
LOG_LEVEL=INFO
# Set to debug to make the SDK log its own export attempts. This is the fastest
# way to find out why no spans arrive.
# OTEL_LOG_LEVEL=debug
