{
  "_comment": [
    "OpenTelemetry dependencies for {{ service_name }} ({{ framework.label }}).",
    "Merge the entries below into your own package.json, then run npm install.",
    "The stable packages (api, core, resources, sdk-trace-base) are on 1.x/2.x;",
    "the SDK distribution and the instrumentation packages are still pre-1.0 and",
    "move together, so upgrade them as a set.",
    "Generated by {{ generator }}.",
    "Background reading: {{ article }}"
  ],
  "dependencies": {
    "@opentelemetry/api": "^1.9.0",
    "@opentelemetry/core": ">=1.30.0",
    "@opentelemetry/resources": ">=1.30.0",
    "@opentelemetry/sdk-node": ">=0.57.0",
    "@opentelemetry/sdk-trace-base": ">=1.30.0",
    "@opentelemetry/semantic-conventions": ">=1.28.0",
{% if spec.protocol == 'grpc' %}
    "@opentelemetry/exporter-trace-otlp-grpc": ">=0.57.0",
{% elif spec.protocol == 'http' %}
    "@opentelemetry/exporter-trace-otlp-proto": ">=0.57.0",
{% endif %}
    "@opentelemetry/instrumentation-http": ">=0.57.0",
{% if framework.key == 'express' %}
    "@opentelemetry/instrumentation-express": ">=0.47.0"
{% elif framework.key == 'fastify' %}
    "@opentelemetry/instrumentation-fastify": ">=0.44.0"
{% elif framework.key == 'nestjs' %}
    "@opentelemetry/instrumentation-express": ">=0.47.0",
    "@opentelemetry/instrumentation-nestjs-core": ">=0.44.0"
{% elif framework.key == 'plain' %}
    "@opentelemetry/instrumentation-undici": ">=0.10.0"
{% endif %}
  },
  "scripts": {
    "start:otel": "node --require ./otel/tracing.js ./src/server.js"
  }
}
