/**
 * Express instrumentation wiring for {{ service_name }}.
 *
 * `tracing.js` requires this module and hands the array to the SDK, so nothing
 * here needs calling from your application code. Your server stays untouched:
 *
 *   node --require ./otel/tracing.js ./src/server.js
 *
 * The HTTP instrumentation creates the server span; the Express one adds the
 * middleware and route-handler spans nested underneath it, which is what shows
 * you *which* middleware spent the time.
 *
 * Generated by {{ generator }}.
 * Background reading: {{ article }}
 */

'use strict';

const { HttpInstrumentation } = require('@opentelemetry/instrumentation-http');
const {
  ExpressInstrumentation,
} = require('@opentelemetry/instrumentation-express');

/** Paths polled by infrastructure; their spans carry no information. */
const IGNORED_PATHS = ['/health', '/healthz', '/readyz', '/livez', '/metrics'];

function isIgnored(url) {
  if (!url) {
    return false;
  }
  const path = url.split('?')[0];
  return IGNORED_PATHS.includes(path);
}

const instrumentations = [
  new HttpInstrumentation({
    ignoreIncomingRequestHook: (request) => isIgnored(request.url),
    requestHook: (span, request) => {
      // `request` is an IncomingMessage on the server side and a
      // ClientRequest on the outgoing side; only the former has `headers`.
      const userAgent = request.headers && request.headers['user-agent'];
      if (userAgent) {
        span.setAttribute('user_agent.original', userAgent);
      }
    },
  }),
  new ExpressInstrumentation({
    // Middleware that only forwards adds noise to every trace.
    ignoreLayersType: ['middleware'],
  }),
];

module.exports = { instrumentations, isIgnored };
