/**
 * NestJS instrumentation wiring for {{ service_name }}.
 *
 * NestJS bootstraps its module graph on import, so the SDK has to be loaded
 * first. Preload it rather than importing it from `main.ts`:
 *
 *   node --require ./otel/tracing.js dist/main.js
 *
 * (When you run through `nest start`, add the same flag via
 * `NODE_OPTIONS="--require ./otel/tracing.js"`.)
 *
 * Three layers are instrumented: the HTTP server span, the Express adapter
 * underneath Nest, and the Nest controller/provider spans that tell you which
 * handler ran.
 *
 * Generated by {{ generator }}.
 * Background reading: {{ article }}
 */

'use strict';

const { HttpInstrumentation } = require('@opentelemetry/instrumentation-http');
const {
  ExpressInstrumentation,
} = require('@opentelemetry/instrumentation-express');
const {
  NestInstrumentation,
} = require('@opentelemetry/instrumentation-nestjs-core');

/** Paths polled by infrastructure; their spans carry no information. */
const IGNORED_PATHS = ['/health', '/healthz', '/readyz', '/livez', '/metrics'];

function isIgnored(url) {
  if (!url) {
    return false;
  }
  const path = url.split('?')[0];
  return IGNORED_PATHS.includes(path);
}

const instrumentations = [
  new HttpInstrumentation({
    ignoreIncomingRequestHook: (request) => isIgnored(request.url),
  }),
  new ExpressInstrumentation({
    ignoreLayersType: ['middleware'],
  }),
  new NestInstrumentation(),
];

module.exports = { instrumentations, isIgnored };
