/**
 * Fastify instrumentation wiring for {{ service_name }}.
 *
 * `tracing.js` requires this module and hands the array to the SDK:
 *
 *   node --require ./otel/tracing.js ./src/server.js
 *
 * Fastify hooks are patched at plugin registration time, so the preload order
 * matters more here than with most frameworks: if Fastify is required before
 * the SDK starts, the hook spans are missing and only the bare HTTP span
 * survives.
 *
 * Generated by {{ generator }}.
 * Background reading: {{ article }}
 */

'use strict';

const { HttpInstrumentation } = require('@opentelemetry/instrumentation-http');
const {
  FastifyInstrumentation,
} = require('@opentelemetry/instrumentation-fastify');

/** Paths polled by infrastructure; their spans carry no information. */
const IGNORED_PATHS = ['/health', '/healthz', '/readyz', '/livez', '/metrics'];

function isIgnored(url) {
  if (!url) {
    return false;
  }
  const path = url.split('?')[0];
  return IGNORED_PATHS.includes(path);
}

const instrumentations = [
  new HttpInstrumentation({
    ignoreIncomingRequestHook: (request) => isIgnored(request.url),
  }),
  new FastifyInstrumentation({
    requestHook: (span, info) => {
      // The route template, not the concrete path: "/orders/:id".
      const routeConfig = info.request && info.request.routeOptions;
      if (routeConfig && routeConfig.url) {
        span.setAttribute('http.route', routeConfig.url);
      }
    },
  }),
];

module.exports = { instrumentations, isIgnored };
