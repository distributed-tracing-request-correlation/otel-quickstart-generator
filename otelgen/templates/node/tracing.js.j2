/**
 * OpenTelemetry tracing bootstrap for {{ service_name }}.
 *
 * This file must run before anything else, so the instrumentation can patch
 * modules such as `http` before your application requires them:
 *
 *   node --require ./otel/tracing.js ./src/server.js
 *
 * Set `OTEL_LOG_LEVEL=debug` to make the SDK log its own export attempts; that
 * is the fastest way to diagnose a pipeline that produces no spans.
 *
 * Exporter: {{ backend.label }}{% if spec.exports_to_collector %} via the local OpenTelemetry Collector{% endif %}.
 * Sampling: {{ sampling.description }}.
 *
 * Generated by {{ generator }}.
 * Background reading: {{ article }}
 */

'use strict';

const { NodeSDK } = require('@opentelemetry/sdk-node');
const resourcesApi = require('@opentelemetry/resources');
const {
{% if sampling.kind == 'always_off' %}
  AlwaysOffSampler,
{% endif %}
{% if sampling.kind in ('always_on', 'parentbased') %}
  AlwaysOnSampler,
{% endif %}
  BatchSpanProcessor,
{% if spec.protocol == 'console' %}
  ConsoleSpanExporter,
{% endif %}
{% if sampling.kind in ('head', 'parentbased') %}
  ParentBasedSampler,
{% endif %}
{% if sampling.kind == 'head' %}
  TraceIdRatioBasedSampler,
{% endif %}
} = require('@opentelemetry/sdk-trace-base');
const {
  CompositePropagator,
  W3CBaggagePropagator,
  W3CTraceContextPropagator,
} = require('@opentelemetry/core');
const {
  ATTR_SERVICE_NAME,
  ATTR_SERVICE_VERSION,
} = require('@opentelemetry/semantic-conventions');
{% if spec.protocol == 'grpc' %}
const { OTLPTraceExporter } = require('@opentelemetry/exporter-trace-otlp-grpc');
{% elif spec.protocol == 'http' %}
const { OTLPTraceExporter } = require('@opentelemetry/exporter-trace-otlp-proto');
{% endif %}

const { instrumentations } = require('./instrumentation');

const SERVICE_NAME = process.env.OTEL_SERVICE_NAME || '{{ service_name }}';
const SERVICE_VERSION = process.env.SERVICE_VERSION || '{{ service_version }}';
const DEPLOYMENT_ENVIRONMENT =
  process.env.DEPLOYMENT_ENVIRONMENT || '{{ environment }}';
{% if spec.protocol != 'console' %}
const OTLP_ENDPOINT =
  process.env.OTEL_EXPORTER_OTLP_TRACES_ENDPOINT || '{{ spec.traces_endpoint }}';
{% endif %}

/**
 * Process identity attached to every span.
 *
 * `resourceFromAttributes` is the current API; the `Resource` class was the
 * older one. Supporting both keeps this file working across the 1.x -> 2.x
 * boundary of `@opentelemetry/resources`.
 */
function buildResource() {
  const attributes = {
    [ATTR_SERVICE_NAME]: SERVICE_NAME,
    [ATTR_SERVICE_VERSION]: SERVICE_VERSION,
    'deployment.environment.name': DEPLOYMENT_ENVIRONMENT,
    'deployment.environment': DEPLOYMENT_ENVIRONMENT,
  };
  if (typeof resourcesApi.resourceFromAttributes === 'function') {
    return resourcesApi.resourceFromAttributes(attributes);
  }
  return new resourcesApi.Resource(attributes);
}

/** Sampling policy: {{ sampling.description }}. */
function buildSampler() {
{% if sampling.kind == 'head' %}
  // ParentBasedSampler keeps the decision consistent across the whole trace:
  // only a root span consults the ratio, children follow their parent.
  const ratio = Number(
    process.env.OTEL_TRACES_SAMPLER_ARG || '{{ '%.4g'|format(sampling.ratio) }}',
  );
  return new ParentBasedSampler({ root: new TraceIdRatioBasedSampler(ratio) });
{% elif sampling.kind == 'always_on' %}
  return new AlwaysOnSampler();
{% elif sampling.kind == 'always_off' %}
  return new AlwaysOffSampler();
{% else %}
  return new ParentBasedSampler({ root: new AlwaysOnSampler() });
{% endif %}
}

/** Span exporter for {{ backend.label }}. */
function buildExporter() {
{% if spec.protocol == 'console' %}
  return new ConsoleSpanExporter();
{% else %}
  const headers = {};
{% for name, env_var in spec.headers %}
  if (process.env.{{ env_var }}) {
    headers['{{ name }}'] = process.env.{{ env_var }};
  }
{% endfor %}
  return new OTLPTraceExporter({
    url: OTLP_ENDPOINT,
    headers,
    timeoutMillis: 10000,
  });
{% endif %}
}

const sdk = new NodeSDK({
  resource: buildResource(),
  sampler: buildSampler(),
  // Batching keeps export off the request path: spans are queued and flushed
  // every few seconds, or sooner when the batch fills up.
  spanProcessors: [
    new BatchSpanProcessor(buildExporter(), {
      maxQueueSize: 2048,
      maxExportBatchSize: 512,
      scheduledDelayMillis: 5000,
      exportTimeoutMillis: 30000,
    }),
  ],
  // W3C traceparent/tracestate plus W3C baggage. Baggage does not travel
  // unless its propagator is registered here alongside trace context.
  textMapPropagator: new CompositePropagator({
    propagators: [new W3CTraceContextPropagator(), new W3CBaggagePropagator()],
  }),
  instrumentations,
});

sdk.start();

let shuttingDown = false;

/** Flush queued spans and stop the SDK. Safe to call more than once. */
async function shutdown() {
  if (shuttingDown) {
    return;
  }
  shuttingDown = true;
  try {
    await sdk.shutdown();
  } catch (error) {
    // Never let telemetry teardown mask the real exit reason.
    console.error('opentelemetry shutdown failed', error);
  }
}

for (const signal of ['SIGTERM', 'SIGINT']) {
  process.once(signal, () => {
    shutdown().then(() => {
      process.exit(0);
    });
  });
}

module.exports = { sdk, shutdown };
