/**
 * Instrumentation wiring for plain Node.js: {{ service_name }}.
 *
 *   node --require ./otel/tracing.js ./src/index.js
 *
 * No framework here, so alongside the HTTP instrumentation this module exports
 * `withSpan`, a helper for manual spans. The reason to use it rather than
 * `startSpan` directly is context: `startActiveSpan` puts the span on the async
 * context, so anything awaited inside becomes a child. A span created without
 * it produces an orphan.
 *
 * Generated by {{ generator }}.
 * Background reading: {{ article }}
 */

'use strict';

const { SpanStatusCode, trace } = require('@opentelemetry/api');
const { HttpInstrumentation } = require('@opentelemetry/instrumentation-http');
const {
  UndiciInstrumentation,
} = require('@opentelemetry/instrumentation-undici');

/** Paths polled by infrastructure; their spans carry no information. */
const IGNORED_PATHS = ['/health', '/healthz', '/readyz', '/livez', '/metrics'];

function isIgnored(url) {
  if (!url) {
    return false;
  }
  const path = url.split('?')[0];
  return IGNORED_PATHS.includes(path);
}

const instrumentations = [
  new HttpInstrumentation({
    ignoreIncomingRequestHook: (request) => isIgnored(request.url),
  }),
  // Covers global `fetch`, which does not go through the `http` module.
  new UndiciInstrumentation(),
];

const tracer = trace.getTracer('{{ service_name }}', '{{ service_version }}');

/**
 * Run `fn` inside an active span, recording exceptions and always ending it.
 *
 *   await withSpan('reconcile-ledger', { 'ledger.day': day }, async (span) => {
 *     span.setAttribute('rows', rows.length);
 *   });
 */
async function withSpan(name, attributes, fn) {
  return tracer.startActiveSpan(name, { attributes: attributes || {} }, async (span) => {
    try {
      return await fn(span);
    } catch (error) {
      span.recordException(error);
      span.setStatus({ code: SpanStatusCode.ERROR, message: error.message });
      throw error;
    } finally {
      span.end();
    }
  });
}

module.exports = { instrumentations, isIgnored, withSpan };
