/**
 * Structured logging with trace-ID correlation for {{ service_name }}.
 *
 * `log.info('order accepted', { orderId })` emits one JSON object per line,
 * carrying `trace_id` and `span_id` whenever a span is active. The IDs are the
 * lowercase hex form used in the W3C `traceparent` header, which is what
 * {{ backend.label }} indexes on.
 *
 * If you already use pino, the same idea is a mixin:
 *
 *   const pino = require('pino');
 *   const logger = pino({ mixin: () => traceFields() });
 *
 * Generated by {{ generator }}.
 * Background reading: {{ article }}
 */

'use strict';

const { context, trace } = require('@opentelemetry/api');

/** Trace fields for the currently active span, or an empty object. */
function traceFields() {
  const span = trace.getSpan(context.active());
  if (!span) {
    return {};
  }
  const spanContext = span.spanContext();
  if (!spanContext || !spanContext.traceId) {
    return {};
  }
  return {
    trace_id: spanContext.traceId,
    span_id: spanContext.spanId,
    trace_flags: spanContext.traceFlags.toString(16).padStart(2, '0'),
  };
}

function emit(level, message, fields) {
  const record = {
    timestamp: new Date().toISOString(),
    level,
    message,
    'service.name': process.env.OTEL_SERVICE_NAME || '{{ service_name }}',
    ...traceFields(),
    ...(fields || {}),
  };
  const line = JSON.stringify(record);
  if (level === 'error' || level === 'warn') {
    process.stderr.write(line + '\n');
  } else {
    process.stdout.write(line + '\n');
  }
}

const log = {
  debug: (message, fields) => emit('debug', message, fields),
  info: (message, fields) => emit('info', message, fields),
  warn: (message, fields) => emit('warn', message, fields),
  error: (message, fields) => {
    const extra = fields instanceof Error
      ? { error: fields.message, stack: fields.stack }
      : fields;
    emit('error', message, extra);
  },
};

module.exports = { log, traceFields };
