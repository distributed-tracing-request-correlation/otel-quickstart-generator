// gRPC instrumentation for {{ service_name }}.
//
// otelgrpc is a stats handler, not an interceptor. The interceptor API is
// deprecated: stats handlers see streaming messages and trailers as well, so
// they produce correct spans for streaming RPCs too.
//
//	srv := grpc.NewServer(tracing.ServerOptions()...)
//	conn, err := grpc.NewClient(target, tracing.ClientOptions()...)
//
// Trace context travels in gRPC metadata, which the propagator reads and
// writes automatically; the same metadata carries baggage.
//
// Generated by {{ generator }}.
// Background reading: {{ article }}
package tracing

import (
	"context"
	"strings"

	"go.opentelemetry.io/contrib/instrumentation/google.golang.org/grpc/otelgrpc"
	"go.opentelemetry.io/otel/attribute"
	"go.opentelemetry.io/otel/trace"
	"google.golang.org/grpc"
	"google.golang.org/grpc/credentials/insecure"
	"google.golang.org/grpc/stats"
)

// healthService is polled constantly by load balancers and Kubernetes; its
// spans carry no information.
const healthService = "/grpc.health.v1.Health/"

// ServerOptions returns the grpc.ServerOption values that install tracing.
func ServerOptions(extra ...grpc.ServerOption) []grpc.ServerOption {
	options := []grpc.ServerOption{
		grpc.StatsHandler(otelgrpc.NewServerHandler(
			otelgrpc.WithFilter(func(info *stats.RPCTagInfo) bool {
				return !strings.HasPrefix(info.FullMethodName, healthService)
			}),
		)),
	}
	return append(options, extra...)
}

// ClientOptions returns the grpc.DialOption values that install tracing on an
// outbound connection.
func ClientOptions(extra ...grpc.DialOption) []grpc.DialOption {
	options := []grpc.DialOption{
		grpc.WithStatsHandler(otelgrpc.NewClientHandler()),
		// Replace with real transport credentials outside a local network.
		grpc.WithTransportCredentials(insecure.NewCredentials()),
	}
	return append(options, extra...)
}

// Annotate adds attributes to the RPC's server span from inside a handler.
func Annotate(ctx context.Context, attrs ...attribute.KeyValue) {
	span := trace.SpanFromContext(ctx)
	if !span.IsRecording() {
		return
	}
	span.SetAttributes(attrs...)
}
