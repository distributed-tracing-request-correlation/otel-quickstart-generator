// Structured logging with trace-ID correlation for {{ service_name }}.
//
// slog carries a context into every call, which is exactly what is needed to
// pull the active span out and stamp its IDs onto the record:
//
//	slog.SetDefault(tracing.NewLogger())
//	slog.InfoContext(ctx, "order accepted", "order.id", id)
//
// Use the *Context variants (InfoContext, ErrorContext, ...). The plain
// slog.Info has no context, so it cannot know which span is active and the
// line comes out without a trace ID.
//
// Generated by {{ generator }}.
// Background reading: {{ article }}
package tracing

import (
	"context"
	"log/slog"
	"os"

	"go.opentelemetry.io/otel/trace"
)

// TraceHandler wraps a slog.Handler and adds trace_id and span_id.
type TraceHandler struct {
	inner slog.Handler
}

// NewTraceHandler wraps an existing handler.
func NewTraceHandler(inner slog.Handler) *TraceHandler {
	return &TraceHandler{inner: inner}
}

// NewLogger returns a JSON logger that correlates with {{ backend.label }}.
func NewLogger() *slog.Logger {
	level := slog.LevelInfo
	if err := level.UnmarshalText([]byte(env("LOG_LEVEL", "INFO"))); err != nil {
		level = slog.LevelInfo
	}
	base := slog.NewJSONHandler(os.Stdout, &slog.HandlerOptions{Level: level})
	return slog.New(NewTraceHandler(base)).With(
		slog.String("service.name", env("OTEL_SERVICE_NAME", defaultServiceName)),
	)
}

func (h *TraceHandler) Enabled(ctx context.Context, level slog.Level) bool {
	return h.inner.Enabled(ctx, level)
}

func (h *TraceHandler) Handle(ctx context.Context, record slog.Record) error {
	// The IDs are written in the lowercase hex form used by the traceparent
	// header, which is what trace backends index on.
	if sc := trace.SpanContextFromContext(ctx); sc.IsValid() {
		record.AddAttrs(
			slog.String("trace_id", sc.TraceID().String()),
			slog.String("span_id", sc.SpanID().String()),
		)
	}
	return h.inner.Handle(ctx, record)
}

func (h *TraceHandler) WithAttrs(attrs []slog.Attr) slog.Handler {
	return &TraceHandler{inner: h.inner.WithAttrs(attrs)}
}

func (h *TraceHandler) WithGroup(name string) slog.Handler {
	return &TraceHandler{inner: h.inner.WithGroup(name)}
}
