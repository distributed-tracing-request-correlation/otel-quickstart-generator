// OpenTelemetry dependencies for {{ service_name }} ({{ framework.label }}).
//
// Add these to your go.mod, or let the toolchain do it:
//
//	go get go.opentelemetry.io/otel@latest \
//	       go.opentelemetry.io/otel/sdk@latest{% if spec.protocol != 'console' %} \
//	       go.opentelemetry.io/otel/exporters/otlp/otlptrace/otlptrace{{ spec.protocol }}@latest{% else %} \
//	       go.opentelemetry.io/otel/exporters/stdout/stdouttrace@latest{% endif %}
//
//	go mod tidy
//
// The API, SDK and exporters are on the same 1.x line and should be upgraded
// together; the contrib instrumentation modules have their own 0.x line.
//
// Generated by {{ generator }}.
// Background reading: {{ article }}

require (
	go.opentelemetry.io/otel v1.34.0
	go.opentelemetry.io/otel/sdk v1.34.0
	go.opentelemetry.io/otel/trace v1.34.0
{% if spec.protocol == 'grpc' %}
	go.opentelemetry.io/otel/exporters/otlp/otlptrace/otlptracegrpc v1.34.0
{% elif spec.protocol == 'http' %}
	go.opentelemetry.io/otel/exporters/otlp/otlptrace/otlptracehttp v1.34.0
{% else %}
	go.opentelemetry.io/otel/exporters/stdout/stdouttrace v1.34.0
{% endif %}
{% if framework.key == 'net-http' %}
	go.opentelemetry.io/contrib/instrumentation/net/http/otelhttp v0.59.0
{% else %}
	go.opentelemetry.io/contrib/instrumentation/google.golang.org/grpc/otelgrpc v0.59.0
	google.golang.org/grpc v1.70.0
{% endif %}
)
