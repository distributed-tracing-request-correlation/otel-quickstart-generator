package tracing

import (
	"net/http"
	"time"

	"go.opentelemetry.io/contrib/instrumentation/net/http/otelhttp"
	"go.opentelemetry.io/otel/attribute"
	"go.opentelemetry.io/otel/trace"
)

// ignoredPaths are polled by infrastructure; their spans carry no information.
var ignoredPaths = map[string]bool{
	"/health":  true,
	"/healthz": true,
	"/readyz":  true,
	"/livez":   true,
	"/metrics": true,
}

// Handler wraps an http.Handler so each request becomes a SERVER span, with
// the incoming traceparent header used as the parent.
func Handler(next http.Handler) http.Handler {
	instrumented := otelhttp.NewHandler(next, "http.server",
		// Span names come from the matched pattern rather than the raw path,
		// which keeps them low-cardinality.
		otelhttp.WithSpanNameFormatter(func(operation string, r *http.Request) string {
			if pattern := r.Pattern; pattern != "" {
				return pattern
			}
			return r.Method + " " + operation
		}),
		otelhttp.WithFilter(func(r *http.Request) bool {
			return !ignoredPaths[r.URL.Path]
		}),
	)
	return instrumented
}

// InstrumentedClient returns an http.Client that injects trace context into
// every outbound request.
func InstrumentedClient(timeout time.Duration) *http.Client {
	return &http.Client{
		Timeout:   timeout,
		Transport: otelhttp.NewTransport(http.DefaultTransport),
	}
}

// AnnotateRequest adds a couple of attributes to the current server span from
// inside a handler. Call it with the request context, not context.Background.
func AnnotateRequest(r *http.Request, attrs ...attribute.KeyValue) {
	span := trace.SpanFromContext(r.Context())
	if !span.IsRecording() {
		return
	}
	span.SetAttributes(attrs...)
}
